# 이 파일을 복사해서 terraform.tfvars 로 만들고 실제 값 입력
# terraform.tfvars 는 .gitignore 에 포함되어 있어 커밋되지 않음

supabase_url         = "https://your-project.supabase.co"
supabase_service_key = "your-supabase-service-role-key"
resend_api_key       = "your-resend-api-key"
db_password          = "your-rds-password"
acm_cert_arn         = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERT_ID"  # 계정 ID 노출 주의, 실제 ARN으로 교체
github_repo          = "DongjuLee0528/smart-scan"
