# SmartScan Hub 라즈베리파이 환경변수
# .env.example 을 복사해서 .env 로 사용하세요
# cp .env.example .env

# API Gateway URL (변경하지 마세요)
API_GW_URL=https://f7o6rm5r6a.execute-api.ap-northeast-2.amazonaws.com/prod

# AP 설정
AP_SSID=SmartScan-Setup
AP_IP=192.168.4.1
PORTAL_PORT=80

# 스캔 설정
SCAN_WINDOW_SEC=3

# Mock 모드 (실기기 없이 테스트할 때 true)
MOCK_MODE=false
